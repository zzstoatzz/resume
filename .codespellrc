[codespell]
skip = .git,*.pdf,*.pyc,__pycache__,.venv,venv,node_modules,.mypy_cache,.pytest_cache
ignore-words-list = nate,nowack,prefect,marvin,raggy,zzstoatzz,pyo3,dbt,iac,etl,nlg,nli,rag,llm,openai,dx,oss,ts,pydantic,chromadb,databricks,duckdb,vectorstores,agentic,fastmcp,mcp,prefecthq,acq,protonmail,bluesky,bsky,alternatebuild
